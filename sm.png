<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SM International QC</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #0b1e33;
    color: white;
}

header {
    background: #0b1e33;
    padding: 15px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

header img {
    height: 60px;
}

nav a {
    color: white;
    margin: 0 15px;
    text-decoration: none;
    font-weight: bold;
}

.hero {
    text-align: center;
    padding: 80px 20px;
    background: linear-gradient(to right, #0b1e33, #123b63);
}

.hero h1 {
    font-size: 40px;
    margin-bottom: 20px;
}

.hero p {
    font-size: 18px;
    color: #ddd;
}

.btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 25px;
    background: orange;
    color: white;
    text-decoration: none;
    border-radius: 5px;
}

.services {
    display: flex;
    justify-content: space-around;
    padding: 50px;
    background: #f5f5f5;
    color: #000;
}

.card {
    background: white;
    padding: 20px;
    width: 22%;
    text-align: center;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
}

footer {
    background: #0b1e33;
    text-align: center;
    padding: 20px;
}
</style>

</head>

<body>

<header>
    <img src="sm.png" alt="SM Logo">
    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Services</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <h1>SM International Quality Control</h1>
    <p>Inspection - Testing - Certification Services</p>
    <a href="#" class="btn">Contact Us</a>
</section>

<section class="services">
    <div class="card">
        <h3>Inspection</h3>
        <p>Professional inspection services with international standards.</p>
    </div>

    <div class="card">
        <h3>Testing</h3>
        <p>Advanced testing solutions for accurate results.</p>
    </div>

    <div class="card">
        <h3>Certification</h3>
        <p>We provide certification to ensure compliance.</p>
    </div>

    <div class="card">
        <h3>Quality Assurance</h3>
        <p>Delivering excellence through quality control.</p>
    </div>
</section>

<footer>
    <p>📧 sm@sminternationalqc.com | 📞 01096892884</p>
    <p>© 2025 SM International QC</p>
</footer>

</body>
</html>
